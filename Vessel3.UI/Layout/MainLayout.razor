@inherits LayoutComponentBase

<MudThemeProvider Theme="Vessel3Theme.Dark" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="v3-appbar">
        <MudLink Href="" Color="Color.Inherit" Underline="Underline.None" Class="v3-brand">vessel3</MudLink>
        <MudText Typo="Typo.caption" Class="v3-brand-sub">ui</MudText>
        <MudSpacer />
    </MudAppBar>
    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="0" Class="v3-drawer">
        <MudNavMenu Class="v3-nav">
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Storage">buckets</MudNavLink>
            <MudNavLink Href="uploads" Icon="@Icons.Material.Outlined.Upload">uploads</MudNavLink>
            <MudNavLink Href="admin" Icon="@Icons.Material.Outlined.Build">admin</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="v3-main">
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
