@using Amazon.S3
@using Amazon.S3.Model
@inject IAmazonS3 S3
@inject ISnackbar Snackbar

<MudPaper Elevation="0" Class="pa-3 mb-4 v3-card">
    <div class="d-flex align-center" style="gap:12px">
        <MudTextField T="string" @bind-Value="_name" Label="new bucket" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Placeholder="my-bucket" Class="flex-grow-1" Immediate="true" OnKeyDown="OnKey" />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="Create"
                   Disabled="@(_creating || string.IsNullOrWhiteSpace(_name))">
            @(_creating ? "creating…" : "create")
        </MudButton>
    </div>
</MudPaper>

@code {
    [Parameter] public EventCallback OnCreated { get; set; }

    string _name = "";
    bool _creating;

    Task OnKey(KeyboardEventArgs e) =>
        e.Key == "Enter" ? Create() : Task.CompletedTask;

    async Task Create()
    {
        var name = _name.Trim();
        if (name.Length == 0 || _creating) return;
        _creating = true;
        try
        {
            await S3.PutBucketAsync(new PutBucketRequest { BucketName = name });
            _name = "";
            Snackbar.Add($"created {name}", Severity.Success);
            await OnCreated.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"create failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _creating = false;
        }
    }
}
