@page "/admin"
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudText Typo="Typo.h1" Class="mb-1">admin</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">on-demand maintenance. background timers also run on their own.</MudText>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Class="pa-4 v3-card" Style="background:#0a0a0a; border:1px solid #1a1a1a;">
            <MudText Typo="Typo.h3" Class="mb-1">garbage collector</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">delete unreferenced blobs and reap abandoned multipart uploads</MudText>
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="6">
                    <MudNumericField T="long" @bind-Value="_gcBlobAgeSec" Label="min blob age (sec)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField T="long" @bind-Value="_gcUploadAgeSec" Label="min upload age (sec)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Delete" OnClick="RunGc" Disabled="_gcBusy">
                @(_gcBusy ? "running…" : "run")
            </MudButton>
            @if (_gcReport is not null)
            {
                <MudDivider Class="my-3" />
                <div class="v3-mono">blobs deleted: @_gcReport.BlobsDeleted</div>
                <div class="v3-mono">uploads reaped: @_gcReport.UploadsReaped</div>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Class="pa-4 v3-card" Style="background:#0a0a0a; border:1px solid #1a1a1a;">
            <MudText Typo="Typo.h3" Class="mb-1">lifecycle sweep</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">expire current versions per bucket lifecycle config; reap lone delete markers</MudText>
            <MudTextField T="string" @bind-Value="_sweepNow" Label="now override (ISO 8601, optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" Placeholder="@DateTimeOffset.UtcNow.ToString("u")" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Schedule" OnClick="RunSweep" Disabled="_sweepBusy">
                @(_sweepBusy ? "running…" : "run")
            </MudButton>
            @if (_sweepReport is not null)
            {
                <MudDivider Class="my-3" />
                <div class="v3-mono">expired: @_sweepReport.Expired</div>
                <div class="v3-mono">markers reaped: @_sweepReport.MarkersReaped</div>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    long _gcBlobAgeSec = 3600;
    long _gcUploadAgeSec = 604800;
    string _sweepNow = "";
    bool _gcBusy;
    bool _sweepBusy;
    GcReport? _gcReport;
    LifecycleReport? _sweepReport;

    static readonly JsonSerializerOptions JsonOpts = new() { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    sealed record GcReport(int BlobsDeleted, int UploadsReaped);
    sealed record LifecycleReport(int Expired, int MarkersReaped);

    async Task RunGc()
    {
        _gcBusy = true;
        try
        {
            var url = $"admin/gc?blob-age={_gcBlobAgeSec}&upload-age={_gcUploadAgeSec}";
            using var resp = await Http.PostAsync(url, null);
            resp.EnsureSuccessStatusCode();
            _gcReport = await resp.Content.ReadFromJsonAsync<GcReport>(JsonOpts);
            Snackbar.Add($"gc: {_gcReport?.BlobsDeleted} blobs, {_gcReport?.UploadsReaped} uploads", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"gc failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _gcBusy = false;
        }
    }

    async Task RunSweep()
    {
        _sweepBusy = true;
        try
        {
            var url = string.IsNullOrWhiteSpace(_sweepNow) ? "admin/lifecycle" : $"admin/lifecycle?now={Uri.EscapeDataString(_sweepNow)}";
            using var resp = await Http.PostAsync(url, null);
            resp.EnsureSuccessStatusCode();
            _sweepReport = await resp.Content.ReadFromJsonAsync<LifecycleReport>(JsonOpts);
            Snackbar.Add($"sweep: {_sweepReport?.Expired} expired, {_sweepReport?.MarkersReaped} markers reaped", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"sweep failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sweepBusy = false;
        }
    }
}
