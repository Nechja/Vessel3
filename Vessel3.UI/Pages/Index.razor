@page "/"
@using Amazon.S3
@using Amazon.S3.Model
@inject IAmazonS3 S3

<div class="v3-page-head">
    <div class="v3-kicker">object store</div>
    <MudText Typo="Typo.h1">buckets</MudText>
    <div class="v3-sub">@_summary</div>
</div>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" Variant="Variant.Outlined">@_error</MudAlert>
}

<MudPaper Elevation="0" Class="v3-card">
    <MudTable Items="_buckets" Loading="_loading" Hover="true" Dense="true" Striped="false" Bordered="false" Elevation="0" Class="v3-table">
        <HeaderContent>
            <MudTh>name</MudTh>
            <MudTh>created</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudLink Href="@($"buckets/{context.BucketName}")" Class="v3-mono">@context.BucketName</MudLink>
            </MudTd>
            <MudTd>
                <span class="v3-mono v3-muted">@context.CreationDate?.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </MudTd>
            <MudTd Style="text-align:right">
                <MudLink Href="@($"buckets/{context.BucketName}")" Class="v3-mono v3-faint">browse →</MudLink>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="v3-empty">no buckets</div>
        </NoRecordsContent>
        <LoadingContent>
            <div class="v3-empty">loading</div>
        </LoadingContent>
    </MudTable>
</MudPaper>

@code {
    List<S3Bucket> _buckets = [];
    bool _loading = true;
    string? _error;
    string _summary = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resp = await S3.ListBucketsAsync();
            _buckets = resp.Buckets ?? [];
            _summary = $"{_buckets.Count} bucket{(_buckets.Count == 1 ? "" : "s")}";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _summary = "error";
        }
        finally
        {
            _loading = false;
        }
    }
}
